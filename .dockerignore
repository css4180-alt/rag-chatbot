# flyctl launch added from .gitignore
# Python
**/.venv
**/venv
**/__pycache__
**/*.pyc
**/*.pyo
**/*.pyd
**/.Python
**/*.egg-info
**/dist
**/build
**/.pytest_cache
**/.mypy_cache
**/.ruff_cache

# Node
**/node_modules
**/dist
**/.nuxt
**/.output

# IDE
**/.vscode
**/.idea
**/*.swp
**/*.swo
**/.DS_Store
**/Thumbs.db

# Environment variables
**/.env
**/.env.local
**/.env.*.local

# Data (never commit persistent data)
**/backend/data/chroma/*
**/backend/data/sqlite/*
!**/backend/data/chroma/.gitkeep
!**/backend/data/sqlite/.gitkeep

# Logs
**/*.log
**/logs

# Coverage
**/.coverage
**/htmlcov

# flyctl launch added from .pytest_cache/.gitignore
# Created by pytest automatically.
.pytest_cache/**/*

# flyctl launch added from backend/.idea/.gitignore
# Default ignored files
backend/.idea/shelf
backend/.idea/workspace.xml

# flyctl launch added from backend/.pytest_cache/.gitignore
# Created by pytest automatically.
backend/.pytest_cache/**/*

# flyctl launch added from backend/.venv/lib/python3.11/site-packages/chromadb/proto/.gitignore
backend/.venv/lib/python3.11/site-packages/chromadb/proto/**/*_pb2.py*
backend/.venv/lib/python3.11/site-packages/chromadb/proto/**/*_pb2_grpc.py

# flyctl launch added from frontend/.gitignore
# Logs
frontend/**/logs
frontend/**/*.log
frontend/**/npm-debug.log*
frontend/**/yarn-debug.log*
frontend/**/yarn-error.log*
frontend/**/pnpm-debug.log*
frontend/**/lerna-debug.log*

frontend/**/node_modules
frontend/**/dist
frontend/**/dist-ssr
frontend/**/*.local

# Editor directories and files
frontend/**/.vscode/*
!frontend/**/.vscode/extensions.json
frontend/**/.idea
frontend/**/.DS_Store
frontend/**/*.suo
frontend/**/*.ntvs*
frontend/**/*.njsproj
frontend/**/*.sln
frontend/**/*.sw?
fly.toml
