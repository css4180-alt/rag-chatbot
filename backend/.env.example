# --- AWS Bedrock ---
# 로컬 개발에서는 아래 키를 채운다.
# EC2 배포 시에는 IAM 역할을 부여하고 ACCESS_KEY/SECRET 줄은 비워두는 것을 권장.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# 서버리스 모델은 해당 리전에서 첫 호출 시 자동 활성화된다(Model access 페이지는 폐지).
# Claude Haiku 4.5 는 최신·저비용 모델로, 크로스리전 추론 프로파일(us. 접두사)로
# 온디맨드 호출이 가능하다. us-east-1 기준.
BEDROCK_LLM_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# --- 저장소 ---
DATABASE_URL=sqlite:///./data/sqlite/app.db
CHROMA_PERSIST_DIR=./data/chroma

# --- 검색(retrieval) ---
# RETRIEVAL_K: 후보로 가져올 최대 청크 수.
# RETRIEVAL_SCORE_THRESHOLD: 코사인 관련도(0~1)가 이 값 미만인 청크는 버린다.
#   질문과 무관한 문서가 출처/컨텍스트에 섞이는 것을 막는다. 높일수록 엄격.
RETRIEVAL_K=4
RETRIEVAL_SCORE_THRESHOLD=0.3

# --- 접근 제어 / 토큰 쿼터 (공개 데모 비용 보호) ---
# 패스코드 → 계정 매핑. "패스코드:계정,패스코드:계정" 형식.
#   비워두면 인증/쿼터가 전부 비활성화되어(로컬 개발) 누구나 무제한 호출 가능.
#   운영 데모에서는 반드시 채운다. (예: ACCESS_CODES=demo2026:guest,review2026:reviewer)
ACCESS_CODES=
# 로그인 토큰 서명용 비밀키. 운영에서는 반드시 임의의 긴 문자열로 교체.
#   (예: python -c "import secrets; print(secrets.token_urlsafe(32))" 결과 사용)
AUTH_SECRET=dev-insecure-secret-change-me
# 계정 1개가 하루에 쓸 수 있는 LLM 토큰 상한
DAILY_TOKEN_LIMIT_PER_ACCOUNT=50000
# 모든 계정 합산 하루 토큰 상한(전체 비용 캡)
SITE_DAILY_TOKEN_LIMIT=300000
